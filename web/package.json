{
  "name": "obsidianator-web",
  "private": true,
  "version": "0.2.2",
  "description": "Turn an Obsidian vault into a self-contained static website",
  "license": "MIT",
  "homepage": "https://github.com/Fx64b/obsidianator",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fx64b/obsidianator"
  },
  "type": "module",
  "pnpm": {
    "overrides": {
      "uuid": ">=11.1.1"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write",
    "lint": "biome lint --write"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.4.2",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.47",
    "lucide-react": "^1.21.0",
    "mermaid": "^11.16.0",
    "pdfjs-dist": "^5.7.284",
    "radix-ui": "^1.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^9.1.0",
    "react-pdf": "^10.4.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^29.1.1",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
